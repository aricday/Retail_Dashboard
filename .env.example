# RetailNext Pulse Demo backend environment variables
# Copy to .env and fill in values before starting the API.

# Required: OpenAI API key used by /v1/assistant/chat.
OPENAI_API_KEY=sk-REPLACE_ME

# Optional: model override (defaults to gpt-5.4).
OPENAI_MODEL=gpt-5.4

# Optional: custom system prompt for the merchandising assistant.
# Leave blank to use the server's built-in merchandising prompt.
OPENAI_SYSTEM_PROMPT=

# Optional: API server port (defaults to 3000).
PORT=3000
